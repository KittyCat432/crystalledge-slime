<ui:CEAchievementEntry
    xmlns="https://spacestation14.io"
    xmlns:ui="clr-namespace:Content.Client._CE.Achievements.UI">
  <PanelContainer HorizontalExpand="True" Margin="2" StyleClasses="BackgroundPanel">
    <ui:CEAchievementFillBar Name="FillBar" HorizontalExpand="True" VerticalExpand="True" />

    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="8,6,8,6">
      <TextureRect Name="Icon" MinWidth="64" MinHeight="64" MouseFilter="Ignore" Stretch="KeepAspect" Margin="0,0,16,0" Access="Public" />

      <BoxContainer Name="InfoBox" Orientation="Vertical" HorizontalExpand="True" MaxWidth="360">
        <RichTextLabel Name="NameLabel" VerticalAlignment="Center" />
        <RichTextLabel Name="DescLabel" Margin="0,2,0,0" />
      </BoxContainer>

      <Label Name="PercentLabel" MinWidth="60" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0" />
    </BoxContainer>
  </PanelContainer>
</ui:CEAchievementEntry>
